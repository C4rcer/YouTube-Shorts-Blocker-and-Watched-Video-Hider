{
  "manifest_version": 2,
  "name": "YouTube Channel Blocker & Cleaner",
  "version": "3.2.0",
  "description": "Block whole YouTube channels, hide Shorts and already-watched videos, hide individual tiles, and import/export your block list. Best-effort triggers YouTube's native \"Don't recommend channel\".",

  "browser_specific_settings": {
    "gecko": {
      "id": "youtube-blocker@c4rcer",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },

  "permissions": [
    "storage",
    "contextMenus",
    "*://www.youtube.com/*",
    "*://m.youtube.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*", "*://m.youtube.com/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "background": {
    "scripts": ["src/background.js"]
  },

  "browser_action": {
    "default_title": "YouTube Blocker",
    "default_popup": "src/popup.html",
    "default_icon": {
      "48": "icons/icon.svg",
      "96": "icons/icon.svg"
    }
  },

  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  }
}
